{
    "##": "抖音",
    "version": "7.8.0",
    "description": "Douyin PC Client",
    "homepage": "https://www.douyin.com/",
    "license": "Freeware",
    "url": "https://lf-douyin-pc-web.douyinstatic.com/obj/douyin-pc-web/douyin-pc-client/7044145585217083655/releases/357144074/7.8.0/win32-x64/douyin-v7.8.0-win32-x64-default.exe#/dl.7z",
    "hash": "ca07242f97dc94dc4a8a1fa88a17de5156181ed1b93e0d51f91f868849b48c3b",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\*\" -Exclude 'app.7z' -Force -Recurse",
            "Expand-7zipArchive \"$dir\\app.7z\" \"$dir\\$version\" -Removal",
            "Remove-Item \"$dir\\$version\\tray\\douyin_widget.exe\" -Force",
            "Remove-Item \"$dir\\$version\\installer_downloader.exe\" -Force",
            "Copy-Item \"$dir\\$version\\douyin.backup\" \"$dir\\douyin.exe\" -Force",
            "Import-Module \"$bucketsdir\\pscoop\\scripts\\Utils.psm1\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\UserData\" -Target \"$env:APPDATA\\douyin\"",
            "Remove-Module -Name Utils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module \"$bucketsdir\\pscoop\\scripts\\Utils.psm1\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\douyin\"",
            "Remove-Module -Name Utils"
        ]
    },
    "shortcuts": [
        [
            "douyin.exe",
            "抖音"
        ]
    ],
    "persist": "UserData",
    "checkver": {
        "script": [
            "Import-Module \".\\scripts\\Utils.psm1\"",
            "$data = Get-DumplingsInstallerInfo -AppId \"ByteDance.Douyin\"",
            "\"ver:$($data.Version);\"",
            "\"url:$($data.x64);\""
        ],
        "regex": "ver:(?<version>.+?); url:(?<url>.+?);"
    },
    "autoupdate": {
        "url": "$matchUrl#/dl.7z"
    }
}
