{
    "version": "152.0.7962.2",
    "description": "Fast, secure, and free web browser, built for the modern web.",
    "homepage": "https://www.google.com/chrome/canary",
    "depends": "pscoop/chromeplus",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.google.com/chrome/privacy/eula_text.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl.google.com/release2/chrome/bzgw7lvud2uasn5tfllq7ny7by_152.0.7962.2/152.0.7962.2_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "5ee2ee63670ee4bad74e22f29ec5c01011df4ca3677e5934a58991d6eb99892f"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acxrzbf6jmlvo7h5ucabfjlpm3ja_152.0.7962.2/152.0.7962.2_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "24065d0fc980b4806817d881f3c22339870038b411c258035bfdddec6d273936"
        }
    },
    "installer": {
        "script": [
            "Move-Item \"$dir\\Chrome-bin\\*\" \"$dir\" -Force",
            "Remove-Item \"$dir\\Chrome-bin\" -Force -Recurse"
        ]
    },
    "bin": [
        [
            "chrome.exe",
            "chrome-canary",
            "--user-data-dir=\"$persist_dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Google Chrome (Canary)",
            "--user-data-dir=\"$persist_dir\\User Data\""
        ]
    ],
    "post_install": [
        "$chromeplus_dir = \"$(appdir chromeplus)\\current\"",
        "if (Test-Path $chromeplus_dir) {",
        "    Copy-Item \"$chromeplus_dir\\App\\version.dll\" \"$dir\"",
        "    Copy-Item \"$chromeplus_dir\\App\\chrome++.ini\" \"$dir\"",
        "}",
        "$iniPath = \"$dir\\chrome++.ini\"",
        "$actual_data_dir = \"$persist_dir\\User Data\"",
        "$actual_cache_dir = \"$persist_dir\\User Cache\"",
        "$content = Get-Content -Path $iniPath",
        "$content = $content -replace \"{{DATA_DIR}}\", $actual_data_dir",
        "$content = $content -replace \"{{CACHE_DIR}}\", $actual_cache_dir",
        "Set-Content -Path $iniPath -Value $content",
        "$current_dir = Join-Path (Split-Path $dir -Parent) 'current'",
        "$fix_lnk = \"$bucketsdir\\pscoop\\scripts\\Set-ShortcutAumid.ps1\"",
        "$canary_icon = \"$current_dir\\chrome.exe,4\"",
        "& $fix_lnk -ShortcutPath \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Google Chrome (Canary).lnk\" -IconLocation $canary_icon",
        "$taskbar_lnk = \"$env:APPDATA\\Microsoft\\Internet Explorer\\Quick Launch\\User Pinned\\TaskBar\\Google Chrome (Canary).lnk\"",
        "if (Test-Path $taskbar_lnk) {",
        "    & $fix_lnk -ShortcutPath $taskbar_lnk -TargetPath \"$current_dir\\chrome.exe\" -WorkingDirectory $current_dir -IconLocation $canary_icon -Arguments ('--user-data-dir=\"{0}\\User Data\"' -f $persist_dir)",
        "} else {",
        "    powershell -NoProfile -Sta -File \"$bucketsdir\\pscoop\\scripts\\Request-TaskbarPin.ps1\" -AppDir $current_dir",
        "}"
    ],
    "env_set": {
        "CHROME_CANARY_EXECUTABLE": "$original_dir\\chrome.exe"
    },
    "persist": [
        "User Data",
        "User Cache"
    ],
    "checkver": {
        "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
        "regex": "(?sm)<canary32><version>(?<version>[\\d.]+)</version>.+release2/chrome/(?<32>[\\w-]+)_.+<canary64>.+release2/chrome/(?<64>[\\w-]+)_.+</canary64>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.google.com/release2/chrome/$match64_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/canary64[version='$version']/sha256"
                }
            },
            "32bit": {
                "url": "https://dl.google.com/release2/chrome/$match32_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/canary32[version='$version']/sha256"
                }
            }
        }
    }
}
