            "https://github.com/lxgw/LxgwBright-Code/raw/v$version/LxgwBrightCode/LXGWBrightCode-Italic.ttf",
            "https://github.com/lxgw/LxgwBright-Code/raw/v$version/LxgwBrightCode/LXGWBrightCode-Light.ttf",
            "https://github.com/lxgw/LxgwBright-Code/raw/v$version/LxgwBrightCode/LXGWBrightCode-LightItalic.ttf",
