{
    "version": "0.11.15",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://docs.astral.sh/uv/",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.15/uv-x86_64-pc-windows-msvc.zip",
            "hash": "04b98d414a9000e25e5e0e7c9f53749e66b790cdaffc582829e6f58c544ee11c"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.15/uv-i686-pc-windows-msvc.zip",
            "hash": "6a9431f0044a1ff59fd6920f6f982b691acf336b6e26ac8cd40a02b5ab839cd1"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\uv.toml\")) {",
        "    New-Item -Path \"$dir\\uv.toml\" | Out-Null",
        "}"
    ],
    "env_add_path": [
        "py-bin",
        "bin"
    ],
    "env_set": {
        "UV_CONFIG_FILE": "$persist_dir\\uv.toml",
        "UV_PYTHON_INSTALL_DIR": "$persist_dir\\python",
        "UV_PYTHON_BIN_DIR": "$persist_dir\\py-bin",
        "UV_TOOL_DIR": "$persist_dir\\tools",
        "UV_TOOL_BIN_DIR": "$persist_dir\\bin",
        "UV_CACHE_DIR": "$persist_dir\\cache"
    },
    "persist": [
        "bin",
        "py-bin",
        "python",
        "tools",
        "cache",
        "uv.toml"
    ],
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-i686-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
