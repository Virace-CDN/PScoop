{
    "version": "150.0.7871.129",
    "description": "Fast, secure, and free web browser, built for the modern web.",
    "homepage": "https://www.google.com/chrome/",
    "depends": "pscoop/chromeplus",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.google.com/chrome/privacy/eula_text.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl.google.com/release2/chrome/acyfzdooxjhnaladzsvqy5vjwtfq_150.0.7871.129/150.0.7871.129_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "5f1bc7c0ec651d84a1d8377a17f74c216ca571b0993dce24a2210679408b2d2c"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/add6cvpykloysl6aqblebuzsow2q_150.0.7871.129/150.0.7871.129_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "17c0c4f8007a394cd5034ff7fb11ead4e3ffd2ea631c46f59df4788ca3c8c818"
        }
    },
    "installer": {
        "script": [
            "Move-Item \"$dir\\Chrome-bin\\*\" \"$dir\" -Force",
            "Remove-Item \"$dir\\Chrome-bin\" -Force -Recurse"
        ]
    },
    "bin": [
        [
            "chrome.exe",
            "chrome",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Google Chrome",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "post_install": [
        "$chromeplus_dir = \"$(appdir chromeplus)\\current\"",
        "if (Test-Path $chromeplus_dir) {",
        "    Copy-Item \"$chromeplus_dir\\App\\version.dll\" \"$dir\"",
        "    Copy-Item \"$chromeplus_dir\\App\\chrome++.ini\" \"$dir\"",
        "}",
        "$iniPath = \"$dir\\chrome++.ini\"",
        "$actual_data_dir = \"$persist_dir\\User Data\"",
        "$actual_cache_dir = \"$persist_dir\\User Cache\"",
        "$content = Get-Content -Path $iniPath",
        "$content = $content -replace \"{{DATA_DIR}}\", $actual_data_dir",
        "$content = $content -replace \"{{CACHE_DIR}}\", $actual_cache_dir",
        "Set-Content -Path $iniPath -Value $content",
        "$current_dir = Join-Path (Split-Path $dir -Parent) 'current'",
        "$fix_lnk = \"$bucketsdir\\pscoop\\scripts\\Set-ShortcutAumid.ps1\"",
        "$chrome_icon = \"$current_dir\\chrome.exe,0\"",
        "& $fix_lnk -ShortcutPath \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Google Chrome.lnk\" -IconLocation $chrome_icon",
        "$taskbar_lnk = \"$env:APPDATA\\Microsoft\\Internet Explorer\\Quick Launch\\User Pinned\\TaskBar\\Google Chrome.lnk\"",
        "if (Test-Path $taskbar_lnk) {",
        "    & $fix_lnk -ShortcutPath $taskbar_lnk -TargetPath \"$current_dir\\chrome.exe\" -WorkingDirectory $current_dir -IconLocation $chrome_icon -Arguments ('--user-data-dir=\"{0}\\User Data\"' -f $current_dir)",
        "} else {",
        "    powershell -NoProfile -Sta -File \"$bucketsdir\\pscoop\\scripts\\Request-TaskbarPin.ps1\" -AppDir $current_dir",
        "}"
    ],
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\chrome.exe"
    },
    "persist": [
        "User Data",
        "User Cache"
    ],
    "checkver": {
        "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
        "regex": "(?sm)<stable32><version>(?<version>[\\d.]+)</version>.+release2/chrome/(?<32>[\\w-]+)_.+<stable64>.+release2/chrome/(?<64>[\\w-]+)_.+</stable64>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.google.com/release2/chrome/$match64_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/stable64[version='$version']/sha256"
                }
            },
            "32bit": {
                "url": "https://dl.google.com/release2/chrome/$match32_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/stable32[version='$version']/sha256"
                }
            }
        }
    }
}
