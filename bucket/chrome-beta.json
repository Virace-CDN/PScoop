{
    "version": "151.0.7922.34",
    "description": "Fast, secure, and free web browser, built for the modern web.",
    "homepage": "https://www.google.com/chrome/beta",
    "depends": "pscoop/chromeplus",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.google.com/chrome/privacy/eula_text.html"
    },
    "architecture": {
        "64bit": {
            "url": "http://www.google.com/dl/release2/chrome/dlryfpqshqxstlas5kwurilb4u_151.0.7922.34/151.0.7922.34_chrome_installer.exe#/dl.7z",
            "hash": "8c61ace5fa6cdd8a480677a4d4f8f4c27bd480d73d1be2f275d1fd6b962bc19e"
        }
    },
    "installer": {
        "script": "Expand-7zipArchive \"$dir\\chrome.7z\" -ExtractDir 'Chrome-bin' -Removal"
    },
    "bin": [
        [
            "chrome.exe",
            "chrome-beta",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Google Chrome (Beta)",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "checkver": {
        "script": [
            "$json = Invoke-RestMethod -Uri 'https://raw.githubusercontent.com/Bush2021/chrome_installer/refs/heads/main/data.json'",
            "$version = $json.win_beta_x64.version",
            "$url = $json.win_beta_x64.urls[0]",
            "$url -match '/chrome/(?<id>[^_]+)_' | Out-Null",
            "$id = $Matches['id']",
            "Write-Output \"$version|$id\""
        ],
        "regex": "^(?<version>[\\d.]+)\\|(?<id>[a-z0-9]+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.google.com/dl/release2/chrome/$matchId_$version/$version_chrome_installer.exe#/dl.7z",
                "hash": {
                    "mode": "json",
                    "url": "https://github.com/Bush2021/chrome_installer/raw/refs/heads/main/data.json",
                    "jsonpath": "$.win_beta_x64.sha256"
                }
            }
        }
    },
    "post_install": [
        "$chromeplus_dir = $(scoop prefix chromeplus)",
        "if (Test-Path $chromeplus_dir) {",
        "    Copy-Item \"$chromeplus_dir\\App\\version.dll\" \"$dir\"",
        "    Copy-Item \"$chromeplus_dir\\App\\chrome++.ini\" \"$dir\"",
        "}",
        "$current_dir = Join-Path (Split-Path $dir -Parent) 'current'",
        "$fix_lnk = \"$bucketsdir\\pscoop\\scripts\\Set-ShortcutAumid.ps1\"",
        "$beta_icon = \"$current_dir\\chrome.exe,9\"",
        "& $fix_lnk -ShortcutPath \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Google Chrome (Beta).lnk\" -IconLocation $beta_icon",
        "$taskbar_lnk = \"$env:APPDATA\\Microsoft\\Internet Explorer\\Quick Launch\\User Pinned\\TaskBar\\Google Chrome (Beta).lnk\"",
        "if (Test-Path $taskbar_lnk) {",
        "    & $fix_lnk -ShortcutPath $taskbar_lnk -TargetPath \"$current_dir\\chrome.exe\" -WorkingDirectory $current_dir -IconLocation $beta_icon -Arguments ('--user-data-dir=\"{0}\\User Data\"' -f $current_dir)",
        "} else {",
        "    powershell -NoProfile -Sta -File \"$bucketsdir\\pscoop\\scripts\\Request-TaskbarPin.ps1\" -AppDir $current_dir",
        "}"
    ],
    "env_set": {
        "CHROME_BETA_EXECUTABLE": "$original_dir\\chrome.exe"
    },
    "persist": [
        "User Data",
        "User Cache"
    ]
}
